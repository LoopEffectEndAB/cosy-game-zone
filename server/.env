# Server environment variables for local development
# WARNING: do not commit a real secret to version control for production

# Port the server will listen on
PORT=4000

# JWT secret for signing tokens - change for production
JWT_SECRET=your-very-secret-value
# CORS configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080